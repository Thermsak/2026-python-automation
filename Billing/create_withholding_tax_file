# Load the bill list
bill_wb = openpyxl.load_workbook(bill_list_path)
bill_ws = bill_wb["Billing"]

# Process each row (skip the header)
for row in bill_ws.iter_rows(min_row=2, values_only=False):
    doc_number = row[0].value
    if not doc_number:  # Stop if DocNumber is empty
        break
    fill_and_save_withholdingtax(row, withholdingtax_template_path, output_folder)
